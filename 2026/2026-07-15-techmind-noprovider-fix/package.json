{
  "name": "techmind-studio",
  "displayName": "TechMind Studio",
  "description": "Airgapped technical assistant — WAT framework (Workflows, Agent, Tools) backed by your vLLM endpoints. Zero external calls.",
  "version": "1.0.0",
  "publisher": "internal-airgapped",
  "engines": {
    "vscode": "^1.61.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "techmind-sidebar",
          "title": "TechMind",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "techmind-sidebar": [
        {
          "id": "techmind.workflows",
          "name": "Workflows",
          "icon": "media/icon.svg"
        },
        {
          "id": "techmind.tools",
          "name": "Tools",
          "icon": "media/icon.svg"
        },
        {
          "id": "techmind.models",
          "name": "Models",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "techmind.openAgent",
        "title": "TechMind: Open Agent Panel",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "techmind.runWorkflow",
        "title": "TechMind: Run Workflow"
      },
      {
        "command": "techmind.attachActiveFile",
        "title": "TechMind: Attach Active File to Context",
        "icon": "$(file-add)"
      },
      {
        "command": "techmind.attachSelection",
        "title": "TechMind: Send Selection to Agent",
        "icon": "$(arrow-right)"
      },
      {
        "command": "techmind.clearContext",
        "title": "TechMind: Clear Attached Context"
      },
      {
        "command": "techmind.toggleModel",
        "title": "TechMind: Toggle Model Enabled"
      },
      {
        "command": "techmind.checkEndpoints",
        "title": "TechMind: Check Endpoint Health"
      },
      {
        "command": "techmind.diagnostics",
        "title": "TechMind: Run Gateway Diagnostics"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "techmind.attachSelection",
          "group": "techmind",
          "when": "editorHasSelection"
        }
      ],
      "view/title": [
        {
          "command": "techmind.checkEndpoints",
          "when": "view == techmind.models",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "TechMind Studio",
      "properties": {
        "techmind.baseUrl": {
          "type": "string",
          "default": "https://chatbotapi.analytics.idb.gunk.in",
          "description": "Base URL for the internal vLLM gateway (airgapped). No external calls are ever made."
        },
        "techmind.timeoutMs": {
          "type": "number",
          "default": 120000,
          "description": "Request timeout in milliseconds."
        },
        "techmind.guidedMode": {
          "type": "boolean",
          "default": true,
          "description": "Ask one clarifying question before producing complex outputs."
        },
        "techmind.streaming": {
          "type": "string",
          "enum": [
            "auto",
            "on",
            "off"
          ],
          "default": "auto",
          "enumDescriptions": [
            "Try streaming; fall back to a single buffered request if the gateway or a proxy refuses it.",
            "Always stream. Surfaces the error instead of silently falling back — useful for diagnosing a proxy.",
            "Never stream. Responses appear all at once, as they did before."
          ],
          "description": "Whether to request token streaming (SSE) from the gateway."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "node test/markdown.test.js && node test/llmClient.test.js && node test/abort.test.js",
    "pretest": "tsc -p ./",
    "package": "node make-vsix.js",
    "build": "node build.js"
  },
  "devDependencies": {
    "@types/node": "^14.18.63",
    "@types/vscode": "^1.61.0",
    "typescript": "^5.9.3"
  }
}
